# Immutable application images published by each repository.
UI_IMAGE=ghcr.io/typeitorg/boero-ui
UI_VERSION=sha-replace-with-ui-commit
API_IMAGE=ghcr.io/typeitorg/boero-api
API_VERSION=sha-replace-with-api-commit

# Loopback ports used by host Nginx and operational health checks.
UI_HOST_PORT=3000
API_HOST_PORT=8080

# Keep false while staging is served over HTTP.
AUTH_COOKIE_SECURE=false

# Application resource limits.
UI_MEMORY_LIMIT=1024m
UI_CPU_LIMIT=1.0
API_MEMORY_LIMIT=1024m
API_CPU_LIMIT=1.0
POSTGRES_MEMORY_LIMIT=1024m
POSTGRES_CPU_LIMIT=1.0
REDIS_MEMORY_LIMIT=256m
REDIS_CPU_LIMIT=0.5

# PostgreSQL credentials used only inside the Compose network.
DB_NAME=boero_staging
DB_USER=boero
DB_PASSWORD=change-me

# Authentication and refresh-token protection.
JWT_SECRET=change-me-to-a-32-byte-or-longer-secret-for-hs256
REFRESH_REPLAY_ENCRYPTION_KEY=base64-encoded-32-byte-key
REFRESH_REPLAY_TTL=5s

# Optional bootstrap credentials for the first platform administrator.
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=change-me-to-a-strong-password

# Shared container log rotation.
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

